# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==============================================================================
# Dependencies
# ==============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==============================================================================
# Next.js & Build Outputs
# ==============================================================================
/.next/
/out/
/build
/dist

# ==============================================================================
# Local Database & Caches
# ==============================================================================
/.mongo-data
/.mongodb-binaries
/.cache
*.db
*.db-journal
*.sqlite

# ==============================================================================
# Environment & Secrets
# ==============================================================================
# Sensitive credentials and environment configurations
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
# Generic match for env files
.env*
!.env.example
# Security keys / certificates
*.pem
*.key

# ==============================================================================
# IDE / Editor Settings
# ==============================================================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json

# IntelliJ / WebStorm
.idea/

# Editor backups and swap files
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
*.bak

# ==============================================================================
# System & OS Files
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==============================================================================
# Logs & Debugging
# ==============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==============================================================================
# Testing & Coverage
# ==============================================================================
/coverage
.nyc_output

# ==============================================================================
# Caches & Tooling
# ==============================================================================
.eslintcache
.parcel-cache
.turbo
*.tsbuildinfo
next-env.d.ts
.vercel
